package consumer

import (
	"context"
	"net/http"
	"time"

	"github.com/gorilla/websocket"
	"github.com/rs/zerolog/log"
)

type wsMessageC struct {
	conn        *ThingConnection
	MessageType string
	Data        map[string]interface{}
}

// ConnectWebSocket Connect the thing using the WebSocket access
func (t *ThingConnection) ConnectWebSocket(ctx context.Context) {
	if t == nil {
		log.Error().Msg("[consumer:ConnectWebSocket] nil connection")
		return
	}
	wsURL := t.getWSURL()
	for {
		select {
		case <-ctx.Done():
			log.Warn().Str("url", wsURL).Msg("[consumer:ConnectWebSocket] Connecting interrupted by user")
			return
		case <-t.connectWebSocket():
			break
		}
		if t.IsConnected() { // Should come here connected
			select {
			case <-ctx.Done():
				t.gracefullyShutdown()
				return
			case err := <-t.read():
				if err != nil {
					if websocket.IsCloseError(err, websocket.CloseNormalClosure) {
						log.Info().Str("url", wsURL).Msg("[consumer:ConnectWebSocket] Normal Closure")
					} else {
						log.Error().Err(err).Str("url", wsURL).Msg("[consumer:ConnectWebSocket]")
					}
					t.close()
				}
				break // Break the read message loop to go back on connect() to try to reconnect
			}
		}
		// If we go out from the listen() loop we try to reconnect
		log.Info().Str("url", wsURL).Msg("[consumer:ConnectWebSocket] Trying to reconnect...")
	}
}

func (t *ThingConnection) connectWebSocket() <-chan bool {
	if t == nil {
		log.Error().Msg("[consumer:connect] nil connection")
		return nil
	}
	wsURL := t.getWSURL()
	success := make(chan bool, 1)
	go func() {
		for {
			ws := websocket.DefaultDialer
			wsConn, _, err := ws.Dial(wsURL, http.Header{"Sec-WebSocket-Protocol": []string{"webthing"}})

			t.mu.Lock()
			t.Conn = wsConn
			t.dialErr = err
			t.isConnected = err == nil
			t.mu.Unlock()

			if err == nil {
				log.Info().Str("url", wsURL).Msg("[consumer:connect] WebSocket connection successfully established")
				t.connWait.reset()
				success <- true
				return
			}

			nextDuration := t.connWait.nextDuration()
			log.Error().Err(err).Str("url", wsURL).Msgf("[consumer:connect] WebSocket connect will try again in %s.", nextDuration.String())

			time.Sleep(nextDuration)
		}
	}()
	return success
}

// read monitor the WebSocket Messages
func (t *ThingConnection) read() <-chan error {
	if t == nil {
		log.Error().Msg("[consumer:read] nil connection")
		return nil
	}
	result := make(chan error, 1)
	go func() {
		for {
			message := wsMessageC{conn: t}
			err := t.Conn.ReadJSON(&message)
			if err != nil {
				result <- err
				return
			}

			log.Trace().Msgf("[consumer:listen] Received WebSocket message: %#v", message)
			t.processRxMsg(message)
		}
	}()
	return result
}

func (t *ThingConnection) get() *websocket.Conn {
	if t == nil {
		log.Error().Msg("[consumer:get] nil connection")
		return nil
	}
	t.mu.RLock()
	defer t.mu.RUnlock()

	return t.Conn
}

// setIsConnected sets state for isConnected
func (t *ThingConnection) setIsConnected(state bool) {
	if t == nil {
		log.Error().Msg("[consumer:setIsConnected] nil connection")
		return
	}
	t.mu.Lock()
	defer t.mu.Unlock()

	t.isConnected = state
}

// IsConnected returns the WebSocket connection state
func (t *ThingConnection) IsConnected() bool {
	if t == nil {
		log.Error().Msg("[consumer:IsConnected] nil connection")
		return false
	}
	t.mu.RLock()
	defer t.mu.RUnlock()

	return t.isConnected
}

func (t *ThingConnection) processRxMsg(message wsMessageC) {
	if t == nil {
		log.Error().Msg("[consumer:processRxMsg] nil connection")
		return
	}
	switch message.MessageType {
	case "propertyStatus":
		// Send individual notifications
		for property, value := range message.Data {
			for _, s := range t.subscriptions {
				if s.property == property {
					go s.handlerSingle(property, value, s.context...)
				}
			}
		}
		// Send global notifications
		for _, s := range t.subscriptions {
			if s.handlerAll != nil {
				go s.handlerAll(message.Data, s.context...)
			}
		}
		break
	default:
		log.Error().Str("type", message.MessageType).Msg("[consumer:processRxMsg] Unsupported Received message type")
	}

}

// gracefullyShutdown cleanly close the connection by sending a close message
// [TODO] and then waiting (with timeout) for the server to close the connection.
func (t *ThingConnection) gracefullyShutdown() {
	if t == nil {
		log.Error().Msg("[consumer:gracefullyShutdown] nil connection")
		return
	}
	log.Info().Msg("[consumer:gracefullyShutdown] Sending WebSocket Closing message to server")
	err := t.WriteControl(websocket.CloseMessage,
		websocket.FormatCloseMessage(websocket.CloseNormalClosure, ""),
		time.Time{})
	if err != nil {
		log.Error().Err(err).Msg("[consumer:gracefullyShutdown] WebSocket Close")
		return
	}
	t.Close()
}

// close closes the underlying network connection without
// sending or waiting for a close frame.
func (t *ThingConnection) close() {
	if t == nil {
		log.Error().Msg("[consumer:close] nil connection")
		return
	}
	if t.get() != nil {
		t.mu.Lock()
		t.Conn.Close()
		t.mu.Unlock()
	}

	t.setIsConnected(false)
}
