package thing

import (
	"io"
	"net/http"
	"sync"
	"time"

	"github.com/project-eria/go-wot/thing"

	"github.com/gorilla/websocket"
	"github.com/rs/zerolog/log"
)

var upgrader = websocket.Upgrader{
	ReadBufferSize:  1024,
	WriteBufferSize: 1024,
	Subprotocols:    []string{"webthing"},
}

type thingWSHandler struct {
	webSocketConnections map[string]*wsConnection
	mu                   sync.RWMutex
	waitWebSocket        sync.WaitGroup
}

type wsConnection struct {
	conn *websocket.Conn
	mu   sync.RWMutex
}

type wsMessage struct {
	key         string
	thing       *thing.Thing
	MessageType string
	Data        map[string]interface{}
}

func (h *thingHandler) webSocket(w http.ResponseWriter, r *http.Request) {
	log.Debug().Str("uri", r.RequestURI).Msg("[thing:webSocket] Received Thing WebSocket request")

	if r.Header.Get("Sec-Websocket-Protocol") != "webthing" {
		log.Error().Msg("[thing:webSocket] Connection not using webthing protocol")
		w.WriteHeader(http.StatusBadRequest)
		io.WriteString(w, "Connection not using webthing protocol")
		return
	}

	// TODO Handle Origin for debug plugins
	upgrader.CheckOrigin = func(r *http.Request) bool { return true }

	conn, err := upgrader.Upgrade(w, r, http.Header{"Sec-WebSocket-Protocol": []string{r.Header.Get("Sec-WebSocket-Protocol")}})
	if err != nil {
		log.Warn().Str("uri", r.RequestURI).Err(err).Msg("[thing:webSocket] WebSocket Upgrade")
		return
	}
	key := r.Header.Get("Sec-Websocket-Key")
	wsConn := h.addWSConnection(key, conn)

	for {
		message := wsMessage{key: key, thing: h.Thing}
		err := conn.ReadJSON(&message)
		if websocket.IsCloseError(err, websocket.CloseNormalClosure) {
			log.Debug().Str("key", key).Msg("[thing:webSocket] WebSocket Normal Closure")
			h.removeWSConnection(key)
			return
		}
		if err != nil {
			log.Error().Str("key", key).Err(err).Msg("[thing:webSocket] WebSocket error")
			h.removeWSConnection(key)
			return
		}
		log.Trace().Str("key", key).Msgf("[thing:webSocket] Received WebSocket message: %#v", message)
		h.processRxMsg(wsConn, &message)
	}
}

// processRxMsg processes incoming messages
func (h *thingWSHandler) processRxMsg(wsConn *wsConnection, message *wsMessage) {
	log.Debug().Str("key", message.key).Str("type", message.MessageType).Msg("[thing:processRxMsg] Processing WS request")
	switch message.MessageType {
	case "setProperty":
		content, err := message.thing.processSetProperties(message.Data)
		if err != nil {
			wsConn.errorWSRenderer(err.Error())
			log.Error().Str("key", message.key).Err(err).Msg("[thing:processRxMsg] SetProperty request")
			break
		}
		wsConn.jsonWSRenderer(content)
		break
	default:
		wsConn.errorWSRenderer("Unsupported RX request type")
		log.Error().Str("key", message.key).Str("type", message.MessageType).Msg("[thing:processRxMsg] Unsupported RX request type")
	}
}

// processTxMsg processes messages to be send
func (h *thingWSHandler) processTxMsg(message *wsMessage) {
	log.Debug().Str("key", message.key).Str("type", message.MessageType).Msg("[thing:processTxMsg] Processing WS request")
	switch message.MessageType {
	case "propertyStatus":
		// Send the message to all ws connections
		for _, wsConn := range h.webSocketConnections {
			err := wsConn.jsonWSRenderer(message)
			if err != nil {
				log.Error().Str("key", message.key).Err(err).Msg("[thing:processTxMsg] Sending propertyStatus")
			}
		}
		break
	default:
		log.Error().Str("key", message.key).Str("type", message.MessageType).Msg("[thing:processTxMsg] Unsupported TX message type")
	}
}

func (c *wsConnection) jsonWSRenderer(content interface{}) error {
	c.mu.Lock()
	defer c.mu.Unlock()
	return c.conn.WriteJSON(content)
}

func (c *wsConnection) errorWSRenderer(message string) {
	c.mu.Lock()
	defer c.mu.Unlock()
	c.conn.WriteJSON(map[string]string{"error": message})
}

func (h *thingWSHandler) addWSConnection(key string, conn *websocket.Conn) *wsConnection {
	if h == nil {
		log.Error().Msg("[webSocket:addWSConnection] nil server")
	}
	log.Debug().Str("key", key).Msg("[webSocket:addWSConnection] Register WS Connection")
	h.mu.Lock()
	defer h.mu.Unlock()
	wsConn := &wsConnection{conn: conn}
	h.webSocketConnections[key] = wsConn
	h.waitWebSocket.Add(1)
	return wsConn
}

func (h *thingWSHandler) removeWSConnection(key string) {
	if h == nil {
		log.Error().Msg("[webSocket:removeWSConnection] nil server")
	}
	h.mu.Lock()
	defer h.mu.Unlock()

	if _, ok := h.webSocketConnections[key]; ok {
		//		conn.Close() // don't close the websocket.Conn or ReadJSON returns a "use of closed network connection" error
		delete(h.webSocketConnections, key)
		h.waitWebSocket.Done()
	}
}

func (h *thingWSHandler) gracefullWSShutdown() {
	if h == nil {
		log.Error().Msg("[webSocket:gracefullWSShutdown] nil server")
	}
	h.mu.RLock()
	conns := h.webSocketConnections
	h.mu.RUnlock()

	for key, wsConn := range conns {
		log.Trace().Str("key", key).Msg("[webSocket:gracefullWSShutdown] Send Close message")
		err := wsConn.conn.WriteControl(websocket.CloseMessage,
			websocket.FormatCloseMessage(websocket.CloseNormalClosure, ""),
			time.Time{})
		if err != nil {
			log.Error().Str("key", key).Err(err).Msg("[webSocket:gracefullWSShutdown] Sending error")
		}
		h.removeWSConnection(key)
	}
}
